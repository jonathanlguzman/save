import Foundation

nonisolated struct PathSection: Identifiable, Sendable {
    let id: String
    let sectionNumber: String
    let title: String
    let chapterId: String

    var displayLabel: String {
        "\(sectionNumber) \(title)"
    }
}

nonisolated struct PathChapter: Identifiable, Sendable {
    let id: String
    let number: Int
    let title: String
    let description: String
    let unitId: String
    let sections: [PathSection]
}

nonisolated struct PathUnit: Identifiable, Sendable {
    let id: String
    let title: String
    let chapters: [PathChapter]

    var allSections: [PathSection] {
        chapters.flatMap(\.sections)
    }
}

